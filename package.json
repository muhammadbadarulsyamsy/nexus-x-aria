{
  "name": "nexus-x-aria",
  "version": "0.1.9",
  "description": "Transparent airdrop risk scoring API for Web3 projects.",
  "type": "module",
  "private": false,
  "scripts": {
    "check:version": "grep 'const VERSION = \"0.1.9\";' worker.js",
